{
  "name": "arazzo2openapi",
  "version": "1.0.0",
  "description": "Convert Arazzo workflow documents to OpenAPI documents",
  "keywords": [
    "arazzo",
    "openapi",
    "workflow",
    "api",
    "converter",
    "cli",
    "swagger",
    "rest-api"
  ],
  "author": {
    "name": "Frank Kilcommins @frankkilcommins",
    "email": "fkilcommins@gmail.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankkilcommins/arazzo2openapi"
  },
  "homepage": "https://frankkilcommins.github.io/arazzo2openapi",
  "bugs": {
    "url": "https://github.com/frankkilcommins/arazzo2openapi/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "arazzo2openapi": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli/index.js"
  },
  "dependencies": {
    "@speclynx/apidom-core": "^1.0.0",
    "@speclynx/apidom-json-pointer": "^2.11.0",
    "@speclynx/apidom-ns-arazzo-1": "^1.0.0",
    "@speclynx/apidom-ns-openapi-3-0": "^3.2.0",
    "@speclynx/apidom-ns-openapi-3-1": "^3.2.1",
    "@speclynx/apidom-parser-adapter-arazzo-json-1": "^1.0.0",
    "@speclynx/apidom-parser-adapter-arazzo-yaml-1": "^1.0.0",
    "@speclynx/apidom-parser-adapter-openapi-json-3-0": "^2.10.3",
    "@speclynx/apidom-parser-adapter-openapi-json-3-1": "^2.11.0",
    "@speclynx/apidom-parser-adapter-openapi-yaml-3-0": "^2.10.3",
    "@speclynx/apidom-parser-adapter-openapi-yaml-3-1": "^2.11.0",
    "@speclynx/apidom-reference": "^3.2.1",
    "@swaggerexpert/arazzo-runtime-expression": "^2.0.3",
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "inquirer": "^13.3.0",
    "ora": "^7.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
